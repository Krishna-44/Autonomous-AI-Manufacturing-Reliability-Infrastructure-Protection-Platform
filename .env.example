# ============================================================================
# Autonomous AI Manufacturing Reliability & Infrastructure Protection Platform
#
# Copy to `.env` and edit. Used by docker-compose.yml.
#
# REQUIRED before first activation:
#   POSTGRES_PASSWORD, N8N_ENCRYPTION_KEY, GRAFANA_ADMIN_PASSWORD,
#   at least one AI provider key (OPENAI_API_KEY or ANTHROPIC_API_KEY),
#   ADMIN_TOKEN (for the workflow to authenticate to your MES backend).
#
# Missing optional credentials cause the relevant workflow branches to
# degrade gracefully (mock-safe fallbacks) — they do not crash the workflow.
# ============================================================================

# ---------- Timezone (n8n schedules, Daily Summary, logs) ----------
TZ=Asia/Kolkata

# ---------- Postgres (shared by n8n internal + workflow incident store) ----------
POSTGRES_USER=mes
# MUST set in production. Generate: openssl rand -hex 24
POSTGRES_PASSWORD=changeme-in-env
POSTGRES_DB=mes_incidents
POSTGRES_PORT=5432
# Bind to loopback by default; set 0.0.0.0 to expose on the LAN
POSTGRES_BIND=127.0.0.1

# ---------- Redis (workflow vector memory + chat memory + breaker state) ----------
REDIS_PORT=6379

# ---------- n8n ----------
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678/
# REQUIRED. n8n encrypts stored credentials with this key. Rotating it
# makes all stored credentials unreadable — keep it safe.
# Generate: openssl rand -hex 32
N8N_ENCRYPTION_KEY=
N8N_LOG_LEVEL=info

# ---------- Prometheus ----------
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=15d

# ---------- Grafana ----------
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
# MUST change in production.
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_ROOT_URL=http://localhost:3001/
# Anonymous Viewer access for floor-mounted screens behind plant LAN
GRAFANA_ANON_VIEWER=false

# ---------- Loki ----------
LOKI_PORT=3100

# ---------- Ollama (local LLM, for offline / air-gapped recovery) ----------
OLLAMA_PORT=11434
OLLAMA_KEEP_ALIVE=5m

# ============================================================================
# Workflow API targets — values referenced by the n8n workflow's HTTP nodes
# ============================================================================

# Prometheus endpoint the "Fetch Prometheus Metrics" node calls.
PROMETHEUS_URL=http://prometheus:9090/api/v1/query

# Base URL of your external MES backend (the one that runs the actual
# plant — see backend-patch/ for the recovery routes you need to add
# there). The workflow's Execute-* Recovery nodes POST to this base +
# /admin/recovery/{process,camera,iframe,ffmpeg}/...
MES_API_BASE=http://host.docker.internal:8000

# Bearer token sent on every workflow → MES backend call. Must match
# the ADMIN_TOKEN in your MES backend's .env.
# Generate: openssl rand -hex 32
ADMIN_TOKEN=

# Realtime dashboards the workflow pushes summary updates to.
# Leave blank to disable — workflow continues (onError=continueRegularOutput).
DASHBOARD_WEBHOOK_URL=
VIDEO_DASHBOARD_WEBHOOK_URL=

# Corporate firewall API for "Block Malicious IPs" node.
# Leave blank to skip — workflow logs the would-be block but doesn't call.
FIREWALL_BLOCK_URL=

# Daily Summary email recipients (comma-separated).
OPS_LEADERSHIP_EMAIL=

# ============================================================================
# AI / integration credentials — bound to n8n credentials by name
# ============================================================================

# Core AI providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=

# Vector memory
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX=mes-incidents

# Local LLM fallback for when external providers are unreachable
OLLAMA_FALLBACK_MODEL=llama3.2:3b

# Slack
SLACK_BOT_TOKEN=
SLACK_CHANNEL_CRITICAL=#incidents-critical
SLACK_CHANNEL_HIGH=#incidents-high
SLACK_CHANNEL_MAINTENANCE=#maintenance
SLACK_CHANNEL_CAMERA=#camera-alerts

# Discord (legacy fallback channel)
DISCORD_WEBHOOK_URL=

# Jira
JIRA_BASE_URL=
JIRA_USER_EMAIL=
JIRA_API_TOKEN=
JIRA_SECURITY_PROJECT_KEY=SEC

# GitHub (read-only PAT for the Deployment Monitor node)
GITHUB_PAT=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=

# Gmail
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REFRESH_TOKEN=

# ============================================================================
# Resilience knobs (see backend-patch/ for the matching backend settings)
# ============================================================================
WORKFLOW_HTTP_MAX_RETRIES=3
WORKFLOW_HTTP_BACKOFF_MS=500
CIRCUIT_BREAKER_OPEN_SECONDS=60
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5

# Escalation matrix — comma-separated emails (or @slack-user ids) per tier
ESCALATE_MAINTENANCE=
ESCALATE_SOFTWARE_ENGINEER=
ESCALATE_SUPERVISOR=
ESCALATE_ADMIN=
